# ─────────────────────────────────────────────────────────────────────────────
# PyProxy — Environment Variable Reference
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
PROXY_HTTP_ADDR=:8080         # HTTP proxy listen address
PROXY_HTTPS_ADDR=:8443        # HTTPS (TLS) proxy listen address
PROXY_SOCKS5_ADDR=:1080       # SOCKS5 proxy listen address
PROXY_HEALTH_ADDR=:9090       # Health/metrics endpoint (keep internal)

# ── TLS ───────────────────────────────────────────────────────────────────────
# Leave empty to auto-generate a self-signed dev certificate.
# In production, mount your cert+key and set these paths.
PROXY_TLS_CERT=               # e.g. /certs/server.crt
PROXY_TLS_KEY=                # e.g. /certs/server.key

# ── Authentication ────────────────────────────────────────────────────────────
# Mode: none | basic | ip | both
PROXY_AUTH_MODE=none

# Comma-separated "username:password" pairs (basic or both mode)
# Example: PROXY_AUTH_USERS=alice:s3cr3t,bob:hunter2
PROXY_AUTH_USERS=

# Comma-separated CIDR ranges or plain IPs (ip or both mode)
# Example: PROXY_IP_WHITELIST=10.0.0.0/8,203.0.113.5
PROXY_IP_WHITELIST=

# ── Security ──────────────────────────────────────────────────────────────────
# Block requests to private/loopback/reserved IP ranges (SSRF protection)
PROXY_BLOCK_PRIVATE=true

# Comma-separated hostnames to explicitly block
# Example: PROXY_BLOCKED_HOSTS=ads.example.com,tracker.io
PROXY_BLOCKED_HOSTS=

# ── Performance ───────────────────────────────────────────────────────────────
PROXY_MAX_CONNECTIONS=10000   # Maximum concurrent connections
PROXY_DIAL_TIMEOUT=10         # Upstream dial timeout (seconds)
PROXY_IDLE_TIMEOUT=90         # Idle connection timeout (seconds)
PROXY_BUFFER_SIZE=65536       # Per-direction relay buffer (bytes)

# ── Observability ─────────────────────────────────────────────────────────────
PROXY_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
PROXY_LOG_FORMAT=json         # json | text
